<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org">

<suite name="Lead Manager Automation Suite" parallel="tests" thread-count="2">

    <!-- Listeners for Professional HTML Reporting -->
    <listeners>
        <listener class-name="com.leadmanager.qa.utils.ExtentReportManager" />
    </listeners>

    <!-- Test Set 1: UI Automation (Selenium + POM) -->
    <test name="UI Role-Based &amp; Functional Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.leadmanager.qa.ui.LeadUiTests"/>
        </classes>
    </test>

    <!-- Test Set 2: API Automation (RestAssured) -->
    <test name="API Security &amp; Endpoint Tests">
        <classes>
            <class name="com.leadmanager.qa.api.LeadApiTests"/>
        </classes>
    </test>

</suite>
